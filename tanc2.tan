# ============================================================
# tanc2 — TAN ILE YAZILMIS derleyici, KONTROL AKISI destekli
# C YOK. Tan -> x86-64 asm -> as -> ld -> ELF
#
# mini-Tan v2 grameri (ASCII anahtar kelimeler):
#   <ad> = <ifade>
#   yaz <ifade>
#   eger <ifade>  ...  son
#   iken <ifade>  ...  son
# Iflade: tam sayi, degisken, + - * /, ( ), == != < > <= >=
#
# Kullanim: tanc2 <girdi.mt> <cikti-binary>
# ============================================================

işlev bosluk_mu(k)
    döndür k == 32 veya k == 9 veya k == 13
son

işlev rakam_mi(k)
    döndür k >= 48 ve k <= 57
son

işlev harf_mi(k)
    döndür (k >= 97 ve k <= 122) veya (k >= 65 ve k <= 90) veya k == 95
son

işlev islec_karakteri_mi(h)
    döndür h == "=" veya h == "!" veya h == "<" veya h == ">"
son

# tokenle: iki karakterli isleçleri (== != <= >=) tek token yapar
işlev tokenle(satir)
    tokenler = []
    n = uzunluk(satir)
    i = 0
    iken i < n
        k = kod(satir[i])
        eğer bosluk_mu(k) ise
            i = i + 1
        değilse eğer rakam_mi(k) ise
            s = ""
            iken i < n ve rakam_mi(kod(satir[i]))
                s = s + satir[i]
                i = i + 1
            son
            tokenler = ekle(tokenler, s)
        değilse eğer harf_mi(k) ise
            ad = ""
            iken i < n ve (harf_mi(kod(satir[i])) veya rakam_mi(kod(satir[i])))
                ad = ad + satir[i]
                i = i + 1
            son
            tokenler = ekle(tokenler, ad)
        değilse eğer islec_karakteri_mi(satir[i]) ise
            ilk = satir[i]
            eğer i + 1 < n ve satir[i + 1] == "=" ise
                tokenler = ekle(tokenler, ilk + "=")
                i = i + 2
            değilse
                tokenler = ekle(tokenler, ilk)
                i = i + 1
            son
        değilse
            tokenler = ekle(tokenler, satir[i])
            i = i + 1
        son
    son
    döndür tokenler
son

işlev sayi_token_mu(t)
    eğer uzunluk(t) == 0 ise
        döndür 0
    son
    döndür rakam_mi(kod(t))
son

işlev son_oge(l)
    n = uzunluk(l)
    eğer n == 0 ise
        döndür ""
    son
    döndür l[n - 1]
son

işlev cikar_son(l)
    yeni = []
    n = uzunluk(l)
    i = 0
    iken i < n - 1
        yeni = ekle(yeni, l[i])
        i = i + 1
    son
    döndür yeni
son

işlev karsilastirma_mi(t)
    döndür t == "==" veya t == "!=" veya t == "<" veya t == ">" veya t == "<=" veya t == ">="
son

işlev aritmetik_mi(t)
    döndür t == "+" veya t == "-" veya t == "*" veya t == "/"
son

işlev islec_mi(t)
    döndür aritmetik_mi(t) veya karsilastirma_mi(t)
son

işlev oncelik(op)
    eğer karsilastirma_mi(op) ise
        döndür 1
    son
    eğer op == "+" veya op == "-" ise
        döndür 2
    son
    eğer op == "*" veya op == "/" ise
        döndür 3
    son
    döndür 0
son

# shunting-yard: infix -> RPN.  Islem onceligini TAN uygular.
işlev rpn_yap(tokenler, basla)
    cikti = []
    yigin = []
    i = basla
    n = uzunluk(tokenler)
    iken i < n
        t = tokenler[i]
        eğer islec_mi(t) ise
            iken uzunluk(yigin) > 0 ve islec_mi(son_oge(yigin)) ve oncelik(son_oge(yigin)) >= oncelik(t)
                cikti = ekle(cikti, son_oge(yigin))
                yigin = cikar_son(yigin)
            son
            yigin = ekle(yigin, t)
        değilse eğer t == "(" ise
            yigin = ekle(yigin, t)
        değilse eğer t == ")" ise
            iken uzunluk(yigin) > 0 ve son_oge(yigin) != "("
                cikti = ekle(cikti, son_oge(yigin))
                yigin = cikar_son(yigin)
            son
            yigin = cikar_son(yigin)
        değilse
            cikti = ekle(cikti, t)
        son
        i = i + 1
    son
    iken uzunluk(yigin) > 0
        cikti = ekle(cikti, son_oge(yigin))
        yigin = cikar_son(yigin)
    son
    döndür cikti
son

işlev setcc_kodu(op)
    eğer op == "==" ise
        döndür "sete"
    son
    eğer op == "!=" ise
        döndür "setne"
    son
    eğer op == "<" ise
        döndür "setl"
    son
    eğer op == ">" ise
        döndür "setg"
    son
    eğer op == "<=" ise
        döndür "setle"
    son
    döndür "setge"
son

# RPN -> x86-64 assembly (yigin makinesi)
işlev rpn_asm(rpn)
    nl = karakter(10)
    kod = ""
    her t rpn içinde
        eğer islec_mi(t) ise
            kod = kod + "    pop rcx" + nl
            kod = kod + "    pop rax" + nl
            eğer t == "+" ise
                kod = kod + "    add rax, rcx" + nl
            değilse eğer t == "-" ise
                kod = kod + "    sub rax, rcx" + nl
            değilse eğer t == "*" ise
                kod = kod + "    imul rax, rcx" + nl
            değilse eğer t == "/" ise
                kod = kod + "    cqo" + nl
                kod = kod + "    idiv rcx" + nl
            değilse
                kod = kod + "    cmp rax, rcx" + nl
                kod = kod + "    " + setcc_kodu(t) + " al" + nl
                kod = kod + "    movzx rax, al" + nl
            son
            kod = kod + "    push rax" + nl
        değilse eğer sayi_token_mu(t) ise
            kod = kod + "    mov rax, " + t + nl
            kod = kod + "    push rax" + nl
        değilse
            kod = kod + "    mov rax, qword ptr [v_" + t + "]" + nl
            kod = kod + "    push rax" + nl
        son
    son
    döndür kod
son

işlev iceriyor_mu(liste, x)
    her e liste içinde
        eğer e == x ise
            döndür 1
        son
    son
    döndür 0
son

işlev yardimci_asm()
    nl = karakter(10)
    a = ""
    a = a + "yaz_sayi:" + nl
    a = a + "    push rbp" + nl
    a = a + "    mov rbp, rsp" + nl
    a = a + "    sub rsp, 32" + nl
    a = a + "    mov rax, rdi" + nl
    a = a + "    lea rcx, [rbp-1]" + nl
    a = a + "    mov byte ptr [rcx], 10" + nl
    a = a + "    xor r8, r8" + nl
    a = a + "    cmp rax, 0" + nl
    a = a + "    jge .Lpoz" + nl
    a = a + "    mov r8, 1" + nl
    a = a + "    neg rax" + nl
    a = a + ".Lpoz:" + nl
    a = a + "    cmp rax, 0" + nl
    a = a + "    jne .Ljegit" + nl
    a = a + "    dec rcx" + nl
    a = a + "    mov byte ptr [rcx], 48" + nl
    a = a + "    jmp .Lisaret" + nl
    a = a + ".Ljegit:" + nl
    a = a + "    mov r9, 10" + nl
    a = a + ".Ldongu:" + nl
    a = a + "    cmp rax, 0" + nl
    a = a + "    je .Lisaret" + nl
    a = a + "    xor rdx, rdx" + nl
    a = a + "    div r9" + nl
    a = a + "    add dl, 48" + nl
    a = a + "    dec rcx" + nl
    a = a + "    mov [rcx], dl" + nl
    a = a + "    jmp .Ldongu" + nl
    a = a + ".Lisaret:" + nl
    a = a + "    cmp r8, 0" + nl
    a = a + "    je .Lyazdir" + nl
    a = a + "    dec rcx" + nl
    a = a + "    mov byte ptr [rcx], 45" + nl
    a = a + ".Lyazdir:" + nl
    a = a + "    mov rsi, rcx" + nl
    a = a + "    lea rdx, [rbp]" + nl
    a = a + "    sub rdx, rcx" + nl
    a = a + "    mov rax, 1" + nl
    a = a + "    mov rdi, 1" + nl
    a = a + "    syscall" + nl
    a = a + "    leave" + nl
    a = a + "    ret" + nl
    a = a + nl
    döndür a
son

# ---------------- ANA DERLEYICI ----------------
nl = karakter(10)
girdi = arg(1)
cikti = arg(2)
kaynak = oku(girdi)
satirlar = parçala(kaynak, "\n")

# 1. gecis: degiskenleri topla
degiskenler = []
her satir satirlar içinde
    tk = tokenle(satir)
    eğer uzunluk(tk) >= 2 ise
        eğer tk[1] == "=" ise
            eğer iceriyor_mu(degiskenler, tk[0]) == 0 ise
                degiskenler = ekle(degiskenler, tk[0])
            son
        son
    son
son

# 2. gecis: govde assembly'si + blok yigini
govde = ""
blok_no = []      # her acik blogun etiket numarasi
blok_tur = []     # "eger" veya "iken"
sayac = 0

her satir satirlar içinde
    tk = tokenle(satir)
    eğer uzunluk(tk) > 0 ise
        ilk = tk[0]

        eğer ilk == "yaz" ise
            rpn = rpn_yap(tk, 1)
            govde = govde + rpn_asm(rpn)
            govde = govde + "    pop rdi" + nl
            govde = govde + "    call yaz_sayi" + nl

        değilse eğer ilk == "eger" ise
            sayac = sayac + 1
            e = metin(sayac)
            rpn = rpn_yap(tk, 1)
            govde = govde + rpn_asm(rpn)
            govde = govde + "    pop rax" + nl
            govde = govde + "    test rax, rax" + nl
            govde = govde + "    jz .Lson" + e + nl
            blok_no = ekle(blok_no, e)
            blok_tur = ekle(blok_tur, "eger")

        değilse eğer ilk == "iken" ise
            sayac = sayac + 1
            e = metin(sayac)
            govde = govde + ".Lbas" + e + ":" + nl
            rpn = rpn_yap(tk, 1)
            govde = govde + rpn_asm(rpn)
            govde = govde + "    pop rax" + nl
            govde = govde + "    test rax, rax" + nl
            govde = govde + "    jz .Lson" + e + nl
            blok_no = ekle(blok_no, e)
            blok_tur = ekle(blok_tur, "iken")

        değilse eğer ilk == "son" ise
            e = son_oge(blok_no)
            tur = son_oge(blok_tur)
            blok_no = cikar_son(blok_no)
            blok_tur = cikar_son(blok_tur)
            eğer tur == "iken" ise
                govde = govde + "    jmp .Lbas" + e + nl
            son
            govde = govde + ".Lson" + e + ":" + nl

        değilse
            rpn = rpn_yap(tk, 2)
            govde = govde + rpn_asm(rpn)
            govde = govde + "    pop rax" + nl
            govde = govde + "    mov qword ptr [v_" + tk[0] + "], rax" + nl
        son
    son
son

# tam assembly dosyasi
tam = "# tanc2 (Tan ile yazildi) tarafindan uretildi. C yok, libc yok." + nl
tam = tam + ".intel_syntax noprefix" + nl + nl
tam = tam + ".section .bss" + nl
her d degiskenler içinde
    tam = tam + "v_" + d + ": .space 8" + nl
son
tam = tam + nl + ".section .text" + nl + ".global _start" + nl + nl
tam = tam + yardimci_asm()
tam = tam + "_start:" + nl
tam = tam + govde
tam = tam + "    mov rax, 60" + nl
tam = tam + "    xor rdi, rdi" + nl
tam = tam + "    syscall" + nl

yaz_dosya(cikti + ".s", tam)
çalıştır("as", "--64", "-o", cikti + ".o", cikti + ".s")
çalıştır("ld", "-o", cikti, cikti + ".o")
yaz("tanc2: derlendi -> " + cikti)
