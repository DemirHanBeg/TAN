yaz("Tan -> assembly, C yok")

işlev faktoriyel(n)
    eğer n <= 1 ise
        döndür 1
    son
    döndür n * faktoriyel(n - 1)
son

işlev fib(n)
    a = 0
    b = 1
    i = 0
    iken i < n
        t = a + b
        a = b
        b = t
        i = i + 1
    son
    döndür a
son

yaz(faktoriyel(5))
yaz(fib(10))

toplam = 0
i = 1
iken i <= 100
    toplam = toplam + i
    i = i + 1
son
yaz(toplam)
yaz(17 % 5)
yaz(0 - 42)
