# ============================================================
# tanc — TAN İLE YAZILMIŞ mini-Tan derleyicisi
# Girdi dili (mini-Tan, ASCII): her satır
#     <ad> = <ifade>      (atama)
#     yaz <ifade>         (yazdır)
# İfade: tam sayı, + - * /, ( ), değişken.  C precedence uygular.
# Kullanım: tanc <girdi.mt> <cikti-binary>
# ============================================================

işlev boslukMu(k)
    döndür k == 32 veya k == 9 veya k == 13
son

işlev rakamMi(k)
    döndür k >= 48 ve k <= 57
son

işlev harfMi(k)
    döndür (k >= 97 ve k <= 122) veya (k >= 65 ve k <= 90) veya k == 95
son

# bir satırı token listesine böl
işlev tokenle(satir)
    tokenler = []
    n = uzunluk(satir)
    i = 0
    iken i < n
        k = kod(satir[i])
        eğer boslukMu(k) ise
            i = i + 1
        değilse eğer rakamMi(k) ise
            s = ""
            iken i < n ve rakamMi(kod(satir[i]))
                s = s + satir[i]
                i = i + 1
            son
            tokenler = ekle(tokenler, s)
        değilse eğer harfMi(k) ise
            ad = ""
            iken i < n ve (harfMi(kod(satir[i])) veya rakamMi(kod(satir[i])))
                ad = ad + satir[i]
                i = i + 1
            son
            tokenler = ekle(tokenler, ad)
        değilse
            tokenler = ekle(tokenler, satir[i])
            i = i + 1
        son
    son
    döndür tokenler
son

işlev sayiTokenMu(t)
    eğer uzunluk(t) == 0 ise
        döndür 0
    son
    döndür rakamMi(kod(t))
son

# ifade tokenlerini (basla indeksinden) C ifadesine çevir
işlev ifadeC(tokenler, basla)
    c = ""
    i = basla
    n = uzunluk(tokenler)
    iken i < n
        t = tokenler[i]
        eğer sayiTokenMu(t) ise
            c = c + t
        değilse eğer t == "+" veya t == "-" veya t == "*" veya t == "/" ise
            c = c + " " + t + " "
        değilse eğer t == "(" veya t == ")" ise
            c = c + t
        değilse
            c = c + "v_" + t
        son
        i = i + 1
    son
    döndür c
son

işlev iceriyorMu(liste, x)
    her e liste içinde
        eğer e == x ise
            döndür 1
        son
    son
    döndür 0
son

# ---- ANA DERLEYİCİ ----
girdi = arg(1)
cikti = arg(2)
kaynak = oku(girdi)
satirlar = parçala(kaynak, "\n")

# 1. geçiş: değişkenleri topla
degiskenler = []
her satir satirlar içinde
    tk = tokenle(satir)
    eğer uzunluk(tk) >= 2 ise
        eğer tk[1] == "=" ise
            ad = tk[0]
            eğer iceriyorMu(degiskenler, ad) == 0 ise
                degiskenler = ekle(degiskenler, ad)
            son
        son
    son
son

# 2. geçiş: C üret
c = "#include <stdio.h>" + karakter(10)
c = c + "static void yz(double x){ if(x==(long long)x) printf(" + karakter(34) + "%lld" + karakter(92) + "n" + karakter(34) + ",(long long)x); else printf(" + karakter(34) + "%g" + karakter(92) + "n" + karakter(34) + ",x); }" + karakter(10)
c = c + "int main(void){" + karakter(10)
her d degiskenler içinde
    c = c + "double v_" + d + "=0;" + karakter(10)
son

her satir satirlar içinde
    tk = tokenle(satir)
    eğer uzunluk(tk) > 0 ise
        ilk = tk[0]
        eğer ilk == "yaz" ise
            c = c + "yz(" + ifadeC(tk, 1) + ");" + karakter(10)
        değilse
            ad = tk[0]
            c = c + "v_" + ad + " = " + ifadeC(tk, 2) + ";" + karakter(10)
        son
    son
son
c = c + "return 0;" + karakter(10) + "}" + karakter(10)

# C'yi yaz, gcc ile derle
yazDosya(cikti + ".c", c)
çalıştır("gcc", "-O2", "-o", cikti, cikti + ".c", "-lm")
yaz("tanc: derlendi -> " + cikti)
