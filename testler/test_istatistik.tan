içe al "kutuphane/istatistik.tan"

sayılar = [4, 8, 15, 16, 23, 42]

yaz "toplam: " + topla_sayılar(sayılar)
yaz "ortalama: " + ist_ortalama(sayılar)
yaz "medyan: " + medyan(sayılar)
yaz "std sapma: " + std_sapma(sayılar)
yaz "en büyük: " + ist_en_büyük(sayılar)
yaz "en küçük: " + ist_en_küçük(sayılar)
